                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        },
        {
          "name": "Google Sign-In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Google sign-in succeeded', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) pm.environment.set('auth_token', json.data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
